<?php

// Deploy this as /var/www/capture-config.local.php (OUTSIDE /var/www/html,
// so it is never web-servable) and fill in real values. Keep it out of git.

return [
    // Must match DEVICE_CAPTURE_API_KEY on the Home Security Laravel side.
    // Generate with: php -r "echo bin2hex(random_bytes(32)), PHP_EOL;"
    'api_key' => 'REPLACE_WITH_A_LONG_RANDOM_SECRET',

    // Full path to the ffmpeg binary on this server, e.g. `which ffmpeg`.
    'ffmpeg_bin' => '/usr/bin/ffmpeg',

    // Optional: YOLOv8n classification of each captured frame. Leave unset/
    // empty to skip classification entirely (capture still works). The model
    // file itself is bundled in this repo at model/yolov8n.onnx and its path
    // is fixed in capture-url.php — only the Python interpreter is
    // per-server (system python3, or a dedicated venv with onnxruntime,
    // numpy, Pillow installed).
    'classifier_python' => '/opt/classifier/venv/bin/python3',

    // Optional: where request failures and classifier errors get logged.
    // Defaults to sys_get_temp_dir().'/capture-url.log' if unset. Must be
    // writable by the web server user.
    'log_file' => '/var/log/capture-url.log',
];
